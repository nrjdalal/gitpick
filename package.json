{
  "name": "gitpick",
  "version": "4.14.0",
  "description": "Clone exactly what you need aka straightforward project scaffolding!",
  "keywords": [
    "clone",
    "degit",
    "directory",
    "file",
    "folder",
    "git",
    "github",
    "repository",
    "scaffolding",
    "template",
    "url"
  ],
  "homepage": "https://github.com/nrjdalal/gitpick#readme",
  "bugs": "https://github.com/nrjdalal/gitpick/issues",
  "license": "MIT",
  "author": {
    "name": "Neeraj Dalal",
    "email": "admin@nrjdalal.com",
    "url": "https://nrjdalal.com"
  },
  "repository": "nrjdalal/gitpick",
  "funding": "https://github.com/sponsors/nrjdalal",
  "bin": {
    "degit": "./dist/index.mjs",
    "gitpick": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "bunx lefthook install",
    "test": "tsdown && bash tests/cli.sh && bash tests/config.sh",
    "test:cli": "bash tests/cli.sh",
    "test:config": "bash tests/config.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "sort-package-json": "^3.6.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
